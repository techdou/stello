{
  "name": "@stello-ai/session",
  "version": "0.8.0",
  "description": "Session layer for Stello — conversation topology engine",
  "license": "Apache-2.0",
  "author": "Stello Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/stello-agent/stello.git",
    "directory": "packages/session"
  },
  "homepage": "https://github.com/stello-agent/stello#readme",
  "bugs": "https://github.com/stello-agent/stello/issues",
  "keywords": [
    "ai",
    "agent",
    "conversation",
    "session",
    "memory",
    "tree",
    "branching",
    "llm",
    "topology"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "openai": ">=4.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@types/node": "^22.0.0",
    "openai": "^6.32.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
