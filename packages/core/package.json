{
  "name": "@stello-ai/core",
  "version": "0.10.2",
  "description": "The first open-source conversation topology engine",
  "license": "Apache-2.0",
  "author": "Stello Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/stello-agent/stello.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/stello-agent/stello#readme",
  "bugs": "https://github.com/stello-agent/stello/issues",
  "keywords": [
    "ai",
    "agent",
    "conversation",
    "session",
    "memory",
    "tree",
    "branching",
    "llm",
    "topology"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@stello-ai/session": "workspace:^"
  }
}
